# Ephemeral Intent Synthesis System - Environment Configuration

# ============================================================================
# LLM Provider Configuration
# ============================================================================
# Choose your LLM provider: "ollama" (local) or "watsonx" (IBM Cloud)
# Set USE_OLLAMA=true to use local Ollama, false to use IBM watsonx.ai
USE_OLLAMA=true

# ----------------------------------------------------------------------------
# Ollama Configuration (Local AI - Recommended for Development)
# ----------------------------------------------------------------------------
# Install Ollama: https://ollama.ai/
# Start Ollama: ollama serve
# Pull models: ollama pull llama3.2
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# Alternative Ollama models:
# - llama3.2 (3B) - Fast, good for education
# - codellama:7b - Best for programming tutorials
# - mistral:7b - Advanced reasoning
# - phi3:mini - Very fast, lightweight

# ----------------------------------------------------------------------------
# IBM watsonx.ai Configuration (Cloud AI - For Production)
# ----------------------------------------------------------------------------
# Get your credentials from: https://cloud.ibm.com/
WATSONX_API_KEY=your_watsonx_api_key_here
WATSONX_PROJECT_ID=your_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Model Configuration
WATSONX_MODEL_ID=ibm/granite-13b-chat-v2

# ============================================================================
# Application Configuration
# ============================================================================
# Environment: development, staging, production
ENVIRONMENT=development

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================================
# Redis Configuration (for session state)
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ============================================================================
# Biometric Analysis Configuration
# ============================================================================
# Thresholds for cognitive load classification
HIGH_STRESS_THRESHOLD=0.7
LOW_ATTENTION_THRESHOLD=0.4

# Minimum frames required for reliable analysis
MIN_FRAMES_FOR_ANALYSIS=30

# ============================================================================
# RAG Engine Configuration
# ============================================================================
# Vector store settings
VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_DIRECTORY=./data/chroma

# Embedding model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Maximum sources to retrieve
MAX_RAG_SOURCES=5

# ============================================================================
# UI Orchestrator Configuration
# ============================================================================
# Presentation mode thresholds
VOICE_FIRST_THRESHOLD=0.7
TEXT_FIRST_THRESHOLD=0.3

# ============================================================================
# Lifecycle Management
# ============================================================================
# Session timeout in seconds
SESSION_TIMEOUT=300

# Cleanup interval in seconds
CLEANUP_INTERVAL=60

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================================================
# Security
# ============================================================================
# Secret key for JWT tokens (generate with: openssl rand -hex 32)
SECRET_KEY=your_secret_key_here_generate_with_openssl

# JWT expiration in minutes
JWT_EXPIRATION_MINUTES=60

# ============================================================================
# Monitoring & Observability
# ============================================================================
# Prometheus metrics
ENABLE_METRICS=true
METRICS_PORT=9090

# OpenTelemetry
ENABLE_TRACING=false
OTEL_EXPORTER_OTLP_ENDPOINT=

# ============================================================================
# Development Settings
# ============================================================================
# Enable debug mode (DO NOT use in production)
DEBUG=false

# Enable API documentation
ENABLE_DOCS=true

# Mock mode (use when watsonx.ai credentials not available)
MOCK_MODE=false